<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Scrabble Word Whiz - CSW24 Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800;900&family=Lexend:wght@700;900&display=swap');
        
        body { 
            font-family: 'Nunito', sans-serif; 
            background: linear-gradient(135deg, #e0e7ff 0%, #f3e8ff 100%);
            color: #374151; 
            overflow: hidden; 
        }
        
        .heading-font { font-family: 'Lexend', sans-serif; }

        .app-container { width: 100%; height: 100dvh; background: #fafafa; margin: auto; }
        @media (min-width: 500px) {
            .app-container { 
                width: min(450px, calc(92dvh * 9 / 16)); 
                height: min(800px, 92dvh); 
                border-radius: 2.5rem; 
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 12px #ffffff, 0 0 0 16px #cbd5e1; 
            }
        }

        /* Fun Tactile Tiles */
        .scrabble-tile { 
            display: inline-flex; align-items: center; justify-content: center; 
            width: 56px; height: 56px; background: #fcd34d; 
            border-radius: 12px; border-bottom: 6px solid #fbbf24; 
            font-weight: 900; font-size: 1.8rem; text-transform: uppercase; 
            color: #4338ca;
            position: relative; 
            font-family: 'Lexend', sans-serif;
            transition: all 0.1s;
        }
        .scrabble-tile.used { 
            background-color: #e5e7eb !important; border-bottom-color: #d1d5db !important; 
            color: #9ca3af !important; transform: translateY(2px); border-bottom-width: 4px;
        }
        .tile-value { position: absolute; bottom: 3px; right: 5px; font-size: 0.65rem; font-family: 'Nunito', sans-serif; font-weight: 800; color: inherit; }
        
        /* Cuter 3D Buttons */
        .btn-3d {
            transition: all 0.1s; border-bottom-width: 6px;
        }
        .btn-3d:active {
            transform: translateY(4px); border-bottom-width: 2px; margin-bottom: 4px;
        }

        .shake { animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes shake { 10%, 90% { transform: translate3d(-2px, 0, 0); } 20%, 80% { transform: translate3d(3px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-5px, 0, 0); } 40%, 60% { transform: translate3d(5px, 0, 0); } }
        
        .found-word-tag { background: #d1fae5; color: #047857; border: 2px solid #34d399; padding: 4px 12px; border-radius: 99px; font-size: 0.85rem; font-weight: 800; display: inline-block; margin: 3px; text-transform: uppercase; box-shadow: 0 2px 0 #34d399; }
        .missing-word-tag { background: #fee2e2; color: #b91c1c; border: 2px solid #f87171; padding: 4px 12px; border-radius: 99px; font-size: 0.85rem; font-weight: 800; display: inline-block; margin: 3px; text-transform: uppercase; box-shadow: 0 2px 0 #f87171;}
        
        .timer-bar-transition { transition: width 1s linear, background-color 0.3s ease; }
        
        /* Custom scrollbar */
        .screen-scroll::-webkit-scrollbar { width: 8px; }
        .screen-scroll::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 99px; }
    </style>
</head>
<body class="min-h-screen w-full flex items-center justify-center sm:p-4">

    <div id="app" class="app-container overflow-hidden relative flex flex-col">
        <!-- Header -->
        <div class="bg-indigo-500 p-4 text-white text-center flex-shrink-0 z-10 border-b-4 border-indigo-600">
            <h1 class="text-2xl font-black flex items-center justify-center gap-2 heading-font tracking-wide">
                <span class="text-3xl drop-shadow-md">🔠</span> Scrabble Whiz
            </h1>
            <p class="text-indigo-100 text-[10px] uppercase font-black tracking-widest mt-1">CSW24 Edition</p>
        </div>

        <!-- Welcome Screen -->
        <div id="welcome-screen" class="p-6 flex-1 flex flex-col justify-center items-center bg-indigo-50/50">
            <div class="relative w-40 h-40 bg-[#fcd34d] rounded-3xl border-b-8 border-[#fbbf24] shadow-xl flex items-center justify-center mb-8 transform -rotate-6 hover:rotate-0 transition-transform duration-300">
                <span class="text-8xl font-black text-indigo-900 heading-font">W</span>
                <span class="absolute bottom-3 right-4 text-3xl font-black text-indigo-900">4</span>
            </div>
            
            <div class="w-full max-w-sm mb-8 space-y-3">
                <label class="block text-center text-indigo-400 font-black uppercase tracking-widest text-sm">Who's Playing?</label>
                <input type="text" id="player-name-input" class="w-full p-4 border-4 border-indigo-100 rounded-3xl text-center text-2xl font-black text-indigo-800 placeholder-indigo-300 focus:border-indigo-400 focus:outline-none transition-colors shadow-inner" placeholder="Your Name" autocomplete="off">
            </div>

            <button onclick="goToSetup()" class="btn-3d w-full max-w-sm bg-emerald-400 border-emerald-500 text-white py-5 rounded-3xl font-black text-2xl shadow-lg flex justify-center items-center gap-2">
                Let's Play! <span class="text-3xl">🚀</span>
            </button>
        </div>

        <!-- Setup Screen -->
        <div id="setup-screen" class="p-5 flex-1 flex flex-col hidden screen-scroll overflow-y-auto bg-gray-50">
            
            <div class="flex items-center gap-3 bg-white p-3 rounded-2xl shadow-sm border-2 border-gray-100 mb-6">
                <div class="bg-indigo-100 text-2xl p-2 rounded-xl">👋</div>
                <div>
                    <div class="text-[10px] text-gray-400 font-black uppercase tracking-widest leading-none">Welcome back,</div>
                    <div id="setup-player-name" class="font-black text-indigo-800 text-lg leading-none mt-1">Player</div>
                </div>
            </div>

            <div id="main-category-section">
                <h3 class="text-gray-400 text-xs font-black mb-3 uppercase tracking-widest text-center">Choose Your Challenge</h3>
                <div class="grid grid-cols-2 gap-4">
                    <button onclick="selectCategory('2', '2 Letters')" class="btn-3d bg-white border-2 border-gray-200 border-b-6 border-b-gray-300 p-6 rounded-[2rem] text-center cursor-pointer hover:bg-indigo-50 hover:border-indigo-200 flex flex-col items-center justify-center aspect-square shadow-sm">
                        <div class="text-6xl mb-3 drop-shadow-sm">✌️</div>
                        <div class="font-black text-gray-700 text-lg">2 Letters</div>
                    </button>
                    <button onclick="selectCategory('3', '3 Letters')" class="btn-3d bg-white border-2 border-gray-200 border-b-6 border-b-gray-300 p-6 rounded-[2rem] text-center cursor-pointer hover:bg-indigo-50 hover:border-indigo-200 flex flex-col items-center justify-center aspect-square shadow-sm">
                        <div class="text-6xl mb-3 drop-shadow-sm">🤟</div>
                        <div class="font-black text-gray-700 text-lg">3 Letters</div>
                    </button>
                    <button onclick="selectCategory('4', '4 Letters')" class="btn-3d bg-white border-2 border-gray-200 border-b-6 border-b-gray-300 p-6 rounded-[2rem] text-center cursor-pointer hover:bg-indigo-50 hover:border-indigo-200 flex flex-col items-center justify-center aspect-square shadow-sm">
                        <div class="text-6xl mb-3 drop-shadow-sm">🖖</div>
                        <div class="font-black text-gray-700 text-lg">4 Letters</div>
                    </button>
                    <button onclick="selectCategory('Bingo', 'Bingo Stems')" class="btn-3d bg-white border-2 border-gray-200 border-b-6 border-b-gray-300 p-6 rounded-[2rem] text-center cursor-pointer hover:bg-amber-50 hover:border-amber-200 flex flex-col items-center justify-center aspect-square shadow-sm">
                        <div class="text-6xl mb-3 drop-shadow-sm">🎰</div>
                        <div class="font-black text-amber-600 text-lg">Bingo</div>
                    </button>
                </div>
            </div>

            <div id="sub-category-section" class="hidden flex-1 flex flex-col">
                <button onclick="backToCategories()" class="text-gray-400 hover:text-indigo-600 font-black mb-6 flex items-center gap-2 text-sm uppercase tracking-wider transition-colors w-fit"><span class="text-xl">⬅️</span> Go Back</button>
                
                <div class="bg-white border-2 border-indigo-100 p-6 rounded-3xl mb-6 shadow-sm">
                    <label id="selected-cat-name" class="block text-indigo-400 font-black mb-3 uppercase tracking-widest text-xs text-center"></label>
                    <select id="subcat-select" class="w-full p-4 border-2 border-gray-100 rounded-2xl font-black text-lg bg-gray-50 text-indigo-900 focus:border-indigo-400 outline-none cursor-pointer"></select>
                </div>
                
                <button onclick="startGame()" class="btn-3d w-full bg-indigo-500 border-indigo-600 text-white py-5 rounded-3xl font-black text-2xl mt-auto shadow-md">
                    Start Game 🎯
                </button>
            </div>
        </div>

        <!-- Game Screen -->
        <div id="game-screen" class="p-4 flex-1 flex flex-col hidden relative bg-gray-50">
            <div id="pause-overlay" class="absolute inset-0 bg-rose-500/90 backdrop-blur-sm z-40 hidden flex flex-col items-center justify-center text-white rounded-b-3xl">
                <span class="text-8xl mb-4 drop-shadow-lg">⏸️</span>
                <span class="text-4xl font-black tracking-widest heading-font mb-8 text-center uppercase">Game Paused</span>
                
                <button onclick="togglePause()" class="btn-3d bg-white border-b-indigo-100 text-rose-600 py-4 px-10 rounded-3xl font-black text-2xl shadow-xl flex items-center gap-3">
                    RESUME <span class="text-3xl">▶️</span>
                </button>
            </div>
            
            <!-- Cute Top Bar -->
            <div class="flex justify-between items-center mb-4 bg-white p-3 rounded-3xl shadow-sm border-2 border-gray-100">
                <div class="flex items-center gap-2 max-w-[50%]">
                    <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-xl shadow-inner">👤</div>
                    <div class="truncate font-black text-indigo-900 text-sm" id="game-player-name">Player</div>
                </div>
                <div class="text-right">
                    <div class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none">Score</div>
                    <div id="score" class="text-indigo-600 text-3xl font-black heading-font leading-none mt-1">0</div>
                </div>
            </div>
            
            <div class="flex justify-between items-end mb-2 px-2">
                <button onclick="exitToHome()" class="text-gray-400 hover:text-rose-500 font-black text-[10px] uppercase tracking-widest transition-colors">🏠 Exit</button>
                <div class="flex flex-wrap items-center justify-center gap-1">
                    <div id="remaining-words-display" class="text-emerald-600 text-[10px] font-black uppercase bg-emerald-50 px-2 py-0.5 rounded-full shadow-sm border border-emerald-100">Words: 0</div>
                    <div id="remaining-sets-display" class="text-amber-500 text-[10px] font-black uppercase bg-amber-50 px-2 py-0.5 rounded-full shadow-sm border border-amber-100">Sets: 0</div>
                    <div id="progress-display" class="text-indigo-400 text-[9px] font-black uppercase bg-indigo-50 px-2 py-0.5 rounded-full">0 / 0</div>
                </div>
                <button id="header-pause-btn" onclick="togglePause()" class="text-gray-400 hover:text-indigo-500 font-black text-[10px] uppercase tracking-widest transition-colors flex items-center gap-1">
                    <span class="text-base">⏸️</span>
                </button>
            </div>
            
            <div class="w-full bg-gray-200 h-3 rounded-full mb-6 overflow-hidden shadow-inner border border-gray-100">
                <div id="timer-bar" class="bg-gradient-to-r from-indigo-400 to-indigo-600 h-full w-full timer-bar-transition rounded-full"></div>
            </div>
            
            <div id="found-words-list" class="flex flex-wrap justify-center content-center min-h-[50px] mb-4 overflow-y-auto"></div>
            
            <div class="flex-1 flex flex-col justify-center mb-4">
                <div id="tile-display" class="flex flex-wrap justify-center gap-2 mb-6"></div>
                <input type="text" id="answer-input" class="w-full max-w-[250px] mx-auto text-center text-2xl font-black uppercase tracking-widest outline-none border-b-4 border-gray-300 focus:border-indigo-500 pb-2 bg-transparent text-indigo-900 placeholder-gray-300" autocomplete="off" placeholder="____">
                <div id="feedback" class="text-center h-6 mt-3 font-black text-sm uppercase tracking-wide"></div>
            </div>
            
            <div class="grid grid-cols-4 gap-3 mt-auto">
                <button onclick="checkAnswer()" class="btn-3d col-span-2 bg-emerald-400 border-emerald-500 text-white font-black py-4 rounded-3xl shadow-sm text-xl tracking-wider">SUBMIT</button>
                <button onclick="useHint()" class="btn-3d col-span-1 bg-amber-400 border-amber-500 text-white py-4 rounded-3xl shadow-sm text-3xl flex items-center justify-center">💡</button>
                <button onclick="skipWord()" class="btn-3d col-span-1 bg-gray-300 border-gray-400 text-gray-600 py-4 rounded-3xl shadow-sm text-3xl flex items-center justify-center">⏭️</button>
            </div>
        </div>

        <!-- Result Screen -->
        <div id="result-screen" class="p-6 text-center flex-1 flex flex-col justify-center hidden bg-indigo-50/50">
            <div class="text-8xl mb-2 animate-bounce drop-shadow-xl">🎉</div>
            <h2 class="text-3xl font-black text-gray-800 mb-1 heading-font">Great Job,</h2>
            <h3 id="result-player-name" class="text-4xl font-black text-indigo-600 mb-8 heading-font">Player!</h3>
            
            <div class="grid grid-cols-3 gap-2 mb-8">
                <div class="bg-white border-2 border-indigo-100 p-4 rounded-3xl shadow-sm flex flex-col justify-center min-w-0">
                    <div class="text-[10px] font-black text-indigo-400 tracking-widest uppercase mb-1">Score</div>
                    <div id="final-score" class="text-2xl font-black text-indigo-600 heading-font truncate">0</div>
                </div>
                <div class="bg-white border-2 border-emerald-100 p-4 rounded-3xl shadow-sm flex flex-col justify-center min-w-0">
                    <div class="text-[10px] font-black text-emerald-400 tracking-widest uppercase mb-1">Sets</div>
                    <div id="final-solved" class="text-2xl font-black text-emerald-500 heading-font truncate">0</div>
                </div>
                <div class="bg-white border-2 border-amber-100 p-4 rounded-3xl shadow-sm flex flex-col justify-center min-w-0">
                    <div class="text-[10px] font-black text-amber-400 tracking-widest uppercase mb-1">Hit Rate</div>
                    <div id="final-accuracy" class="text-2xl font-black text-amber-500 heading-font truncate">0%</div>
                </div>
            </div>
            
            <div class="mt-auto space-y-3">
                <button onclick="showStudySheet()" id="study-sheet-btn" class="btn-3d w-full bg-amber-100 border-amber-300 text-amber-700 py-4 rounded-3xl font-black hidden shadow-sm text-lg flex items-center justify-center gap-2">
                    <span class="text-2xl">📖</span> Review Study Sheet
                </button>
                <button onclick="resetApp()" class="btn-3d w-full bg-indigo-500 border-indigo-600 text-white py-4 rounded-3xl font-black shadow-sm text-xl flex items-center justify-center gap-2">
                    Play Again
                </button>
            </div>
        </div>

        <!-- Study Modal -->
        <div id="study-modal" class="absolute inset-0 bg-gray-50 z-50 hidden flex flex-col p-6 overflow-y-auto screen-scroll rounded-b-3xl">
            <div class="flex justify-between items-center mb-6 border-b-2 border-gray-200 pb-4 bg-gray-50 sticky top-0 z-10 pt-2">
                <h2 class="text-2xl font-black text-indigo-900 flex items-center gap-2 heading-font"><span class="text-3xl">📚</span> Missed Words</h2>
                <button onclick="closeStudySheet()" class="text-4xl text-gray-400 hover:text-rose-500 transition-colors bg-white w-10 h-10 rounded-full flex items-center justify-center shadow-sm border border-gray-100">&times;</button>
            </div>
            <div id="study-content" class="space-y-4 pb-10"></div>
        </div>
    </div>

