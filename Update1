                "EASTER": ["AERATES","BEATERS","BERATES","REBATES","CERATES","CREATES","ECARTES","SECRETA","DEAREST","DERATES","ESTRADE","REASTED","REDATES","SEDATER","STEARED","TASERED","AFREETS","FEASTER","ERGATES","RESTAGE","AETHERS","HEATERS","REHEATS","AERIEST","SERIATE","RETAKES","SAKERET","ELATERS","REALEST","RELATES","RESLATE","STEALER","REMATES","RETEAMS","STEAMER","TEAMERS","EARNEST","EASTERN","NEAREST","RATEENS","STERANE","ROSEATE","EPATERS","REPEATS","RETAPES","RETEARS","SERRATE","TEARERS","EASTERS","RESEATS","SAETERS","SEAREST","SEATERS","STEARES","TEASERS","TESSERA","ESTREAT","RESTATE","RETASTE","AUSTERE","SWEATER","RETAXES"],
                "RETINA": ["ATEBRIN","CANTIER","CERATIN","CERTAIN","CREATIN","CRINATE","NACRITE","TACRINE","ANTIRED","DETRAIN","TRAINED","ARENITE","RETINAE","TRAINEE","FAINTER","FENITAR","GRANITE","GRATINE","INGRATE","TANGIER","TEARING","HAIRNET","INEARTH","THERIAN","INERTIA","JANTIER","NARTJIE","KERATIN","ENTRAIL","LATRINE","RATLINE","RELIANT","RETINAL","TRENAIL","MERANTI","MINARET","RAIMENT","ENTRAIN","TRANNIE","NOTAIRE","OTARINE","INAPTER","PAINTER","PERTAIN","REPAINT","RETRAIN","TERRAIN","TRAINER","ANESTRI","ANTSIER","NASTIER","RATINES","RESIANT","RETAINS","RETINAS","RETSINA","STAINER","STARNIE","STEARIN","INTREAT","ITERANT","NATTIER","NITRATE","TARTINE","TERTIAN","RUINATE","TAURINE","URANITE","URINATE","TAWNIER","TINWARE"],
                "SATIRE": ["ARISTAE","ASTERIA","ATRESIA","BAITERS","BARITES","REBAITS","TERBIAS","ATRESIC","CRISTAE","RACIEST","STEARIC","ARIDEST","ASTERID","ASTRIDE","DIASTER","DISRATE","STAIDER","STAIRED","TARDIES","TIRADES","TRADIES","AERIEST","SERIATE","FAIREST","AGISTER","AIGRETS","GAITERS","SEAGIRT","STAGIER","STRIGAE","TIRAGES","TRIAGES","HASTIER","SHERIAT","AIRIEST","IRISATE","ARKITES","KARITES","REALIST","RETAILS","SALTIER","SALTIRE","SLATIER","TAILERS","IMARETS","MAESTRI","MAISTER","MASTIER","MISRATE","SEMITAR","SMARTIE","ANESTRI","ANTSIER","NASTIER","RATINES","RESIANT","RETAINS","RETINAS","RETSINA","STAINER","STARNIE","STEARIN","OARIEST","OTARIES","ROASTIE","PAIREST","PARTIES","PASTIER","PIASTER","PIASTRE","PIRATES","PRATIES","RAPIEST","TRAIPSE","ARTSIER","SERRATI","TARRIES","TARSIER","ARSIEST","ARTSIES","SAIREST","SATIRES","TIRASSE","ARTIEST","ARTISTE","ATTIRES","IRATEST","RATITES","STRIATE","TASTIER","TERTIAS","RAVIEST","TAIVERS","VASTIER","VERITAS","WAISTER","WAITERS","WARIEST","WASTRIE"]
            }
        };

        const scrabblePoints = { A:1, B:3, C:3, D:2, E:1, F:4, G:2, H:4, I:1, J:8, K:5, L:1, M:3, N:1, O:1, P:3, Q:10, R:1, S:1, T:1, U:1, V:4, W:4, X:8, Y:4, Z:10 };

        let currentCategory = '2', wordListPool = [], allAnagrams = [], foundWords = [], score = 0, streak = 0, solvedTileSets = 0, isPaused = false, isRevealedMode = false, playerName = "Player", timerInterval = null, timeLeft = 10, maxTime = 12, sessionHistory = [], currentBaseWord = "";

        function showScreen(key) { 
            document.querySelectorAll('#app > div:not(.bg-indigo-500)').forEach(s => s.classList.add('hidden')); 
            const screen = document.getElementById(key + '-screen');
            if (screen) screen.classList.remove('hidden'); 
        }

        function goToWelcome() { showScreen('welcome'); }

        function updatePlayerNameDisplays() {
            const name = playerName || "Player";
            const setupEl = document.getElementById('setup-player-name');
            const gameEl = document.getElementById('game-player-name');
            const resultEl = document.getElementById('result-player-name');
            if (setupEl) setupEl.innerText = name;
            if (gameEl) gameEl.innerText = name;
            if (resultEl) resultEl.innerText = name + "!";
        }

        function goToSetup() { 
            playerName = document.getElementById('player-name-input').value.trim() || "Player"; 
            updatePlayerNameDisplays();
            showScreen('setup'); 
        }

        function backToCategories() { 
            document.getElementById('main-category-section').classList.remove('hidden'); 
            document.getElementById('sub-category-section').classList.add('hidden'); 
        }

        function selectCategory(cat, name) {
            currentCategory = cat;
            document.getElementById('main-category-section').classList.add('hidden');
            document.getElementById('sub-category-section').classList.remove('hidden');
            const catNameLabel = document.getElementById('selected-cat-name');
            if (catNameLabel) catNameLabel.innerText = name;

            const select = document.getElementById('subcat-select'), words = CSW24[cat];
            if (!select) return;
            select.innerHTML = '';
            
            if (cat === 'Bingo') {
                Object.keys(CSW24.Bingo).forEach(stem => { 
                    const opt = document.createElement('option'); 
                    opt.value = stem; 
                    opt.innerText = stem; 
                    select.appendChild(opt); 
                });
            } else {
                const newAdditions = { "3": ["UWU","PWN","VOG","VOM","YEZ","XED","VAG","UMU","TAI","QIN"], "4": ["CHIZ","YEET","MPOX","VOMS","VAXX","VLOG","VOIP","WAQF","YAGE","ZEXE"] };
                let html = `<option value="All">All (${words.length})</option>`;
                if (newAdditions[cat]) html += `<option value="CSW24">✨ CSW24 New</option>`;
                html += `<option value="Heavy">Heavy (J,Q,X,Z)</option>`;
                const counts = {}; words.forEach(w => counts[w[0]] = (counts[w[0]] || 0) + 1);
                Object.keys(counts).sort().forEach(l => { html += `<option value="${l}">${l} (${counts[l]})</option>`; });
                select.innerHTML = html;
            }
        }

        function getWordSelection() {
            const selectEl = document.getElementById('subcat-select');
            if (!selectEl) return [];
            const sub = selectEl.value, all = CSW24[currentCategory];
            if (currentCategory === 'Bingo') return [...CSW24.Bingo[sub]];
            if (sub === 'CSW24') { 
                const list = { "3": ["UWU","PWN","VOG","VOM","YEZ","XED","VAG","UMU","TAI","QIN"], "4": ["CHIZ","YEET","MPOX","VOMS","VAXX","VLOG","VOIP","WAQF","YAGE","ZEXE"] };
                return all.filter(w => list[currentCategory].includes(w));
            }
            if (sub === 'All') return [...all];
            if (sub === 'Heavy') return all.filter(w => /[JQXZ]/.test(w));
            return all.filter(w => w[0] === sub);
        }

        function startGame() { 
            wordListPool = getWordSelection(); 
            score = 0; streak = 0; solvedTileSets = 0; sessionHistory = []; 
            showScreen('game'); 
            nextWord(); 
        }

        function nextWord() {
            if (currentBaseWord) {
                sessionHistory.push({ rack: currentBaseWord.split('').sort().join(''), all: [...allAnagrams], found: [...foundWords] });
            }
            if (wordListPool.length === 0) return endGame();
            
            const idx = Math.floor(Math.random() * wordListPool.length);
            currentBaseWord = wordListPool.splice(idx, 1)[0];
            const selectEl = document.getElementById('subcat-select');
            const master = (currentCategory === 'Bingo' && selectEl) ? CSW24.Bingo[selectEl.value] : CSW24[currentCategory];
            
            allAnagrams = master.filter(w => w.split('').sort().join('') === currentBaseWord.split('').sort().join(''));
            allAnagrams = [...new Set(allAnagrams)];
            
            // NO-REPEAT LOGIC: Remove all anagrams found in this rack from the pool
            wordListPool = wordListPool.filter(w => !allAnagrams.includes(w));

            foundWords = []; isRevealedMode = false;
            renderTiles(currentBaseWord); 
            renderFoundWords(); 
            updateUI(); 
            startTimer();
            
            const input = document.getElementById('answer-input');
            if (input) {
                input.value = ''; 
                input.disabled = false; 
                input.focus(); 
            }
            const fb = document.getElementById('feedback');
            if (fb) fb.innerText = '';
        }

        function renderTiles(word) {
            const container = document.getElementById('tile-display'); 
            if (!container) return;
            container.innerHTML = '';
            word.split('').sort(() => Math.random() - 0.5).forEach(char => {
                const div = document.createElement('div'); div.className = 'scrabble-tile shadow-sm'; div.dataset.letter = char;
                div.innerHTML = `${char}<span class="tile-value">${scrabblePoints[char]||0}</span>`; container.appendChild(div);
            });
        }

        function renderFoundWords() {
            const container = document.getElementById('found-words-list'); 
            if (!container) return;
            container.innerHTML = '';
            allAnagrams.forEach(w => {
                const span = document.createElement('span');
                if (foundWords.includes(w)) { span.className = 'found-word-tag'; span.innerText = w; }
                else if (isRevealedMode) { span.className = 'missing-word-tag'; span.innerText = w; }
                else { span.className = 'inline-block px-4 py-1.5 m-1 bg-white border-2 border-gray-200 rounded-full text-[12px] text-gray-300 font-black shadow-sm'; span.innerText = '?'.repeat(w.length); }
                container.appendChild(span);
            });
        }

        function updateTileColors() {
            const input = document.getElementById('answer-input');
            if (!input) return;
            const typed = input.value.toUpperCase().split('');
            const tiles = Array.from(document.querySelectorAll('#tile-display .scrabble-tile'));
            
            tiles.forEach(t => t.classList.remove('used'));
            typed.forEach(char => {
                const availableTile = tiles.find(t => t.dataset.letter === char && !t.classList.contains('used'));
                if (availableTile) availableTile.classList.add('used');
            });
        }

        function checkAnswer() {
            if (isPaused) return;
            const input = document.getElementById('answer-input'), fb = document.getElementById('feedback');
            if (!input || !fb) return;
            const val = input.value.toUpperCase().trim();
            if (allAnagrams.includes(val) && !foundWords.includes(val)) {
                streak++;
                let wordScore = val.split('').reduce((sum, char) => sum + (scrabblePoints[char] || 0), 0);
                let earned = wordScore * streak;
                foundWords.push(val); score += earned; 
                fb.innerText = `Nice! +${earned}` + (streak > 1 ? ` (${streak}x Streak!)` : ""); 
                fb.className = "text-emerald-500 font-black";
                input.value = ''; renderFoundWords(); updateUI(); updateTileColors();
                
                if (foundWords.length === allAnagrams.length) { 
                    solvedTileSets++; 
                    clearInterval(timerInterval); 
                    setTimeout(nextWord, 1000); 
                } else {
                    startTimer(); 
                    updateUI(); // Ensure display updates when words are found
                }
            } else {
                streak = 0;
                score = Math.max(0, score - 2); 
                fb.innerText = "Nope! -2 pts (Streak lost)"; fb.className = "text-rose-500 font-black";
                input.parentElement.classList.add('shake'); setTimeout(() => input.parentElement.classList.remove('shake'), 500);
                updateUI();
            }
        }

        function startTimer() {
            clearInterval(timerInterval); 
            maxTime = currentCategory === 'Bingo' ? 20 : (currentCategory === '4' ? 15 : 12);
            timeLeft = maxTime; 
            
            const timerBar = document.getElementById('timer-bar');
            if (timerBar) {
                timerBar.classList.remove('timer-bar-transition');
                timerBar.style.width = '100%';
                setTimeout(() => { if(timerBar) timerBar.classList.add('timer-bar-transition'); }, 20);
            }

            timerInterval = setInterval(() => { 
                if (!isPaused) { 
                    timeLeft--; 
                    updateTimerUI(); 
                    if (timeLeft <= 0) { 
                        clearInterval(timerInterval); 
                        revealAnswers(); 
                    } 
                } 
            }, 1000);
        }

        function updateTimerUI() { 
            const bar = document.getElementById('timer-bar');
            if (bar) bar.style.width = (timeLeft / maxTime * 100) + '%'; 
        }

        function revealAnswers() { 
            isRevealedMode = true; streak = 0; renderFoundWords(); 
            const input = document.getElementById('answer-input');
            if (input) input.disabled = true; 
            setTimeout(nextWord, 3000); 
        }
        
        function togglePause() { 
            isPaused = !isPaused; 
            const overlay = document.getElementById('pause-overlay');
            const headerBtn = document.getElementById('header-pause-btn');
            if (overlay) overlay.classList.toggle('hidden', !isPaused);
            if (headerBtn) headerBtn.innerHTML = isPaused ? '<span class="text-lg">▶️</span> RESUME' : '<span class="text-lg">⏸️</span> PAUSE';
            if (!isPaused) {
                const input = document.getElementById('answer-input');
                if (input) input.focus();
            }
        }
        
        function exitToHome() { 
            clearInterval(timerInterval); 
            if (currentBaseWord) {
                sessionHistory.push({ rack: currentBaseWord.split('').sort().join(''), all: [...allAnagrams], found: [...foundWords] });
                currentBaseWord = ""; 
            }
            endGame(); 
        }

        function updateUI() { 
            const scoreEl = document.getElementById('score');
            const progEl = document.getElementById('progress-display');
            const remSetsEl = document.getElementById('remaining-sets-display');
            const remWordsEl = document.getElementById('remaining-words-display');
            
            if (scoreEl) scoreEl.innerText = score; 
            if (progEl) progEl.innerText = `${foundWords.length} / ${allAnagrams.length}`; 
            if (remSetsEl) remSetsEl.innerText = `Sets: ${wordListPool.length}`;
            if (remWordsEl) remWordsEl.innerText = `Words: ${allAnagrams.length - foundWords.length}`;
        }

        function endGame() {
            clearInterval(timerInterval); 
            const fScore = document.getElementById('final-score');
            const fSolved = document.getElementById('final-solved');
            const fAcc = document.getElementById('final-accuracy');
            
            if (fScore) fScore.innerText = score; 
            if (fSolved) fSolved.innerText = solvedTileSets;
            
            let totalT = 0, totalF = 0;
            sessionHistory.forEach(i => { totalT += i.all.length; totalF += i.found.length; });
            if (fAcc) fAcc.innerText = (totalT > 0 ? Math.round((totalF / totalT) * 100) : 0) + '%';

            const studyBtn = document.getElementById('study-sheet-btn');
            if (sessionHistory.length > 0 && studyBtn) studyBtn.classList.remove('hidden');
            showScreen('result');
        }

        function showStudySheet() {
            const content = document.getElementById('study-content'); 
            if (!content) return;
            content.innerHTML = '';
            sessionHistory.forEach(item => {
                const div = document.createElement('div'); div.className = "bg-white p-4 rounded-2xl shadow-sm border-2 border-gray-100";
                div.innerHTML = `<div class="text-[10px] text-gray-400 font-black uppercase tracking-widest mb-2">Tiles: ${item.rack}</div><div class="flex flex-wrap gap-2">${item.all.map(w => `<span class="${item.found.includes(w) ? 'text-emerald-500' : 'text-rose-500 underline'} font-black text-lg">${w}</span>`).join('')}</div>`;
                content.appendChild(div);
            });
            const modal = document.getElementById('study-modal');
            if (modal) modal.classList.remove('hidden');
        }

        function closeStudySheet() { 
            const modal = document.getElementById('study-modal');
            if (modal) modal.classList.add('hidden'); 
        }
        function resetApp() { 
            currentBaseWord = "";
            goToSetup(); 
            backToCategories(); 
        }
        function skipWord() { clearInterval(timerInterval); streak = 0; score = Math.max(0, score - 2); updateUI(); revealAnswers(); }
        function useHint() { 
            const m = allAnagrams.find(w => !foundWords.includes(w)); 
            if (m) { 
                const input = document.getElementById('answer-input');
                if (input) input.value = m[0]; 
                streak = 0; score = Math.max(0, score - 2); updateUI(); updateTileColors(); 
            } 
        }
        
        const answerInput = document.getElementById('answer-input');
        if (answerInput) {
            answerInput.addEventListener('input', updateTileColors);
            answerInput.addEventListener('keypress', e => { if (e.key === 'Enter') checkAnswer(); });
        }
        window.onload = () => showScreen('welcome');
    </script>
